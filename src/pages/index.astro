---
import MainLayout from "@layouts/MainLayout.astro";
---

<MainLayout title="Q-Verse — Приватный Minecraft SMP" activePage="home">
  <main>
    <section class="hero">
      <div class="hero-orb hero-orb-left"></div>
      <div class="hero-orb hero-orb-right"></div>

      <div class="hero-panel glass">
        <div class="hero-kicker">Приватный Minecraft SMP</div>
        <img
          src="/assets/big-logo.webp"
          alt="Q-Verse — логотип"
          class="big-logo"
        />

        <p class="hero-lead">Мир без вайпов, который продолжает жить годами.</p>

        <div class="hero-tags">
          <span class="hero-tag"># Mods</span>
          <span class="hero-tag"># SemiAnarchy</span>
          <span class="hero-tag"># NoWipes</span>
          <span class="hero-tag"># PlayerDriven</span>
        </div>

        <div class="hero-actions">
          <button
            class="btn apply"
            onclick="window.open('https://discord.gg/GWVaEAGXRu')"
          >
            Подать заявку
          </button>

          <button class="ip-box glass">
            <span class="ip-text">play.q-verse.tech</span>
            <span class="ip-icon">⧉</span>
          </button>
        </div>

        <div class="hero-download">
          <button
            class="btn ghost"
            onclick="window.open('https://github.com/QVerseInstitute/Q-Verse-Modpack/releases')"
            >Скачать сборку</button
          >
        </div>

        <div class="hero-meta">
          <div class="hero-meta-item">
            <span class="hero-meta-label">Версия</span>
            <strong>Fabric 1.21.11</strong>
          </div>
          <div class="hero-meta-item">
            <span class="hero-meta-label">Издание</span>
            <strong>Java Edition</strong>
          </div>
          <div class="hero-meta-item">
            <span class="hero-meta-label">Доступ</span>
            <strong>По заявке</strong>
          </div>
        </div>
      </div>
    </section>

    <section class="section onboarding-section">
      <p class="section-label">Старт</p>
      <h2>Как попасть на сервер?</h2>

      <div class="cards">
        <div class="card glass">
          <div class="card-step">
            <img src="/assets/number-1.svg" alt="Шаг 1" />
          </div>
          <h3>Подайте заявку</h3>
          <img
            src="/assets/poses/liquorWbook.webp"
            class="pose"
            alt="LiQu0r с книгой"
          />
          <p>
            Расскажите о себе и своих планах на сервер. <br />
            Заявки подаются через
            <a
              href="https://discord.gg/GWVaEAGXRu"
              class="inline-link"
              target="_blank"
              rel="noopener noreferrer">Discord</a
            >
            и рассматриваются вручную.
          </p>
        </div>

        <div class="card glass">
          <div class="card-step">
            <img src="/assets/number-2.svg" alt="Шаг 2" />
          </div>
          <h3>Дождитесь одобрения</h3>
          <img
            src="/assets/poses/liquorWaiting.webp"
            class="pose"
            alt="LiQu0r в ожидании"
          />
          <p>Важно, чтобы новые игроки подходили по настрою и интересам.</p>
        </div>

        <div class="card glass">
          <div class="card-step">
            <img src="/assets/number-3.svg" alt="Шаг 3" />
          </div>
          <h3>Начните игру</h3>
          <img
            src="/assets/poses/liquorPlaying.webp"
            class="pose"
            alt="LiQu0r играет"
          />
          <p>
            После одобрения вы получите доступ к серверу<br />
            и сможете начать игру.
          </p>
        </div>
      </div>
    </section>
  </main>
</MainLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.ip-box').forEach(btn => {
          btn.addEventListener('click', () => {
              const ip = 'play.q-verse.tech'

              navigator.clipboard.writeText(ip).then(() => {
                  btn.classList.add('copied');
                  setTimeout(() => btn.classList.remove('copied'), 500);
              });
          });
      });
  });
</script>