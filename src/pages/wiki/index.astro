---
import MainLayout from "@/layouts/MainLayout.astro";
---

<MainLayout title="Q-Verse — Архив" , activePage="wiki">
  <main class="page-main page-shell error-page">
    <section class="page-card panel error-card">
      <p class="page-eyebrow">Q-Verse Archive</p>
      <img
        src="assets/poses/quoiDev.webp"
        alt="Qu0i работает над архивом"
        class="error-visual"
      />
      <p class="error-title">Страница ещё не готова</p>
      <p class="error-text">
        Архив всё ещё пополняется новыми записями. Некоторые документы пока находятся
        в обработке и станут доступны позже.
      </p>

      <div class="page-actions">
        <a href="./">
          <button class="btn primary">На главную</button>
        </a>
      </div>
    </section>
  </main>
</MainLayout>
